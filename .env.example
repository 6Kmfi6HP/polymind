# =============================================================================
# Polymind - Environment Configuration
# =============================================================================
# Copy this to .env and fill in your credentials:
#   cp .env.example .env
#
# At minimum, you need one AI provider API key to use natural language
# strategy parsing. A wallet is only needed for live trading.

# =============================================================================
# AI Provider (at least ONE required for AI-powered features)
# =============================================================================

# Anthropic (Claude) - Recommended
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4, GPT-4o)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Default agent to use when not specified: auto, anthropic, openai, google
PREFERRED_AGENT=auto

# =============================================================================
# Wallet (required for live trading only)
# =============================================================================

# Ethereum private key (starts with 0x, 64 hex chars)
# Polymarket API credentials are auto-derived from this key
PRIVATE_KEY=

# =============================================================================
# Trading
# =============================================================================

# Initial capital for paper trading and risk calculations
INITIAL_CAPITAL=1000

# Default to safe mode (no real trades)
DRY_RUN=true

# =============================================================================
# Risk Management
# =============================================================================

MAX_POSITION_SIZE=50
MAX_DAILY_LOSS=100
MAX_DRAWDOWN_PCT=0.30
KELLY_FRACTION=0.25

# =============================================================================
# Notifications (optional)
# =============================================================================

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_LEVELS=WARNING,CRITICAL
